{
  "name": "eunoma-operator-services",
  "private": true,
  "version": "0.1.0",
  "description": "V2 off-chain deoperator services for the Eunoma shielded bridge on Aptos.",
  "workspaces": [
    "shared",
    "deop-protocol",
    "crypto-worker-client",
    "deoperator-node",
    "coordinator",
    "relayer"
  ],
  "scripts": {
    "build": "npm run -w @eunoma/shared build && npm run -w @eunoma/deop-protocol build && npm run -w @eunoma/crypto-worker-client build && npm run -w @eunoma/deoperator-node build && npm run -w @eunoma/coordinator build && npm run -w @eunoma/relayer build",
    "test": "npm run build && npm run -w @eunoma/shared test && npm run -w @eunoma/deop-protocol test && npm run -w @eunoma/crypto-worker-client test && npm run -w @eunoma/deoperator-node test && npm run -w @eunoma/coordinator test && npm run -w @eunoma/relayer test && npm run test:scripts",
    "test:scripts": "npm run test:scripts:vitest && npm run test:scripts:node",
    "test:scripts:vitest": "vitest run --config scripts/vitest.config.ts",
    "test:scripts:node": "node --test scripts/__tests__/local_v2_withdraw_full.test.mjs scripts/__tests__/local_v2_withdraw_full_balance.test.mjs scripts/__tests__/sigma_position_17_parity.test.mjs scripts/__tests__/local_v2_withdraw_resync.test.mjs",
    "tsc": "npm run build",
    "local:cluster:config": "npm run build && node scripts/local_cluster_config.mjs",
    "local:cluster:start": "node scripts/local_cluster_start.mjs",
    "local:dkg:init": "npm run local:cluster:config",
    "local:hpke:init": "node scripts/local_ca_dkg_v2_hpke_init.mjs",
    "local:ca-dkg:v2": "node scripts/local_ca_dkg_v2.mjs",
    "local:vault-ek:derive": "node scripts/local_vault_ek_derive.mjs",
    "local:ca:registration": "node scripts/local_ca_registration.mjs",
    "local:ca-registration:v2": "node scripts/local_ca_registration_v2.mjs",
    "local:vault-setup:v2": "node scripts/local_vault_setup_v2.mjs",
    "local:vault-state:init": "node scripts/local_vault_state_init.mjs",
    "local:vault-state:observe-deposit": "node scripts/local_deposit_observer.mjs",
    "local:mpcca:withdraw:round1": "node scripts/local_mpcca_withdraw_round1.mjs",
    "local:mpcca:frost-attest": "node scripts/local_mpcca_frost_attest.mjs",
    "local:mpcca:withdraw:submit": "node scripts/local_mpcca_withdraw_submit.mjs",
    "local:mpcca:full-smoke": "node scripts/local_mpcca_full_smoke.mjs",
    "local:generate-withdraw-proof": "node scripts/local_generate_withdraw_proof.mjs",
    "local:relayer:dryrun": "node scripts/local_relayer_submit_dryrun.mjs",
    "local:online-frost-dkg-smoke": "node scripts/local_frost_dkg_v2.mjs",
    "local:frost-rotation-apply": "node scripts/local_frost_rotation_apply.mjs",
    "local:frost-rotation-smoke": "node scripts/local_frost_rotation_smoke.mjs",
    "local:smoke": "node scripts/testnet_e2e.mjs",
    "mpc:bootstrap": "node scripts/mpc_spdz_bootstrap.mjs",
    "mpc:check": "node scripts/mpc_spdz_check.mjs",
    "testnet:smoke": "node scripts/testnet_e2e_fail_closed.mjs",
    "testnet:vault:init": "node scripts/testnet_vault_init.mjs",
    "testnet:vault:rollover": "node scripts/testnet_vault_rollover.mjs",
    "testnet:deposit-bindings:init": "node scripts/testnet_init_pending_deposit_bindings.mjs",
    "testnet:withdraw-proofs:init": "node scripts/testnet_init_pending_withdraw_proofs.mjs",
    "testnet:provision:m6d": "node scripts/testnet_provision_m6d.mjs",
    "testnet:e2e": "node scripts/testnet_e2e_v2.mjs",
    "testnet:e2e:fail-closed-stub": "node scripts/testnet_e2e_fail_closed.mjs",
    "testnet:rotate-frost-config": "node scripts/testnet_rotate_frost_config.mjs",
    "privacy:scan": "node -e \"const {spawnSync}=require('node:child_process'); const terms=[['VAULT','_DECRYPTION','_KEY','_HEX'].join(''),['disclosed','_amount'].join(''),['deposit','_blind'].join(''),['withdraw','_blind'].join(''),['/','v1','/'].join(''),['main','_operator','_index'].join(''),['main','-operator'].join(''),['partner','-operator'].join(''),['DKINV','_HEX'].join(''),['dk','_inverse'].join(''),['inverse','Share'].join(''),['dk','Inverse'].join(''),['inv','_share'].join('')].join('|'); const r=spawnSync('rg',['-n',terms,'shared','deop-protocol','crypto-worker-client','deoperator-node','coordinator','relayer'],{stdio:'inherit'}); process.exit(r.status===1?0:(r.status??1));\""
  },
  "devDependencies": {
    "@noble/ed25519": "^3.1.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
