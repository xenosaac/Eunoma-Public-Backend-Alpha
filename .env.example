# Eunoma DeOperator V2 env vars (example)
# Copy to .env for local development. Never commit real values.

# ===== Aptos network =====
APTOS_NETWORK=testnet
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1

# ===== Bridge 合约 (Eunoma testnet active deploy: blocker1_l4_key_rotation_2026_05_12) =====
# 历史部署 (dormant)：W6.4 2026-05-10 = 0x8268f56b... / 0x9545e5ea...
#                     AptosShield   = 0x7825166d... / 0xe596a6ca...
# 当前 active deploy 见 STATUS.md + TESTNET_ADDRESSES.md。
BRIDGE_PACKAGE_ADDRESS=0x5bf0ecca9b84c884fa0a7a8525dfedbeccabfe6f1fd199476e032d705dfaabb0
VAULT_RESOURCE_ADDRESS=0xe71cca7ceadc8d213afeb4ca1168a3f6a95d81d5e68a2afdbda6bdadd08ec4eb

# ===== Shared V2 roster =====
# JSON-encoded DeoperatorRoster from @eunoma/deop-protocol.
# Must contain exactly seven nodes and threshold 5.
DEOPERATOR_ROSTER_JSON=

# Optional Postgres DSNs for persistent V2 metadata stores.
COORDINATOR_DATABASE_URL=
DEOPERATOR_DATABASE_URL=

# ===== Coordinator =====
COORDINATOR_HOST=127.0.0.1
COORDINATOR_PORT=4200
COORDINATOR_BEARER_TOKEN=
# JSON object mapping node slot strings ("0".."6") to bearer tokens.
# These are used for coordinator-to-node forwarding and are not published in the roster.
DEOPERATOR_NODE_BEARER_TOKENS_JSON=

# ===== Deoperator node =====
DEOPERATOR_SLOT=0
DEOPERATOR_NODE_ID=node-0
DEOPERATOR_HOST=127.0.0.1
DEOPERATOR_PORT=4100
DEOPERATOR_BEARER_TOKEN=

# Rust worker endpoint for DKG/FROST/MPC work.
# If unset, TypeScript services fail closed.
CRYPTO_WORKER_URL=http://127.0.0.1:4400
CRYPTO_WORKER_SLOT=0
CRYPTO_WORKER_HOST=127.0.0.1
CRYPTO_WORKER_PORT=4400
CRYPTO_WORKER_STATE_ROOT=.agent-local/eunoma-v2
CRYPTO_WORKER_STATE_DIR=.agent-local/eunoma-v2/slot-0

# Required by `npm run local:cluster:config`.
# Must come from Aptos-compatible threshold CA DKG/registration tooling.
# The local runner intentionally refuses to synthesize this value.
LOCAL_VAULT_EK_HEX=

# Vault TwistedEd25519 encryption pubkey (32 bytes hex)
# 对应 VAULT_DECRYPTION_KEY_HEX 的公钥；deposit/withdraw 脚本和 /v1/app/config 路由会用。
# 公开值，可以直接 commit；但留空让脚本从链上 vault 资源里读才是正解。
VAULT_EK_HEX=

# Bridge-spare recipient TwistedEd25519 keypair (32 bytes hex) —— testnet 测试用收款方
RECIPIENT_ENCRYPTION_KEY_HEX=

# ===== Relayer =====
RELAYER_HOST=127.0.0.1
RELAYER_PORT=4300
RELAYER_BEARER_TOKEN=

# ===== Admin / relayer transaction keys =====
# These are transaction submitter keys only. No full vault CA key belongs here.
ADMIN_PRIVATE_KEY_HEX=
RELAYER_PRIVATE_KEY_HEX=

# ===== Testnet rotation (FROST DKG admin tx) =====
# aptos CLI profile name with admin signer authority for rotate_deoperator_config_v2.
# Used by scripts/testnet_rotate_frost_config.mjs.
ADMIN_PROFILE=
