# mvp-backend env vars (example)
# 复制为 .env（本地）或在 process env 里设置；切勿 commit 真值。
# .env / .env.local 已在 .gitignore 中。

# ===== Aptos 网络 =====
APTOS_NETWORK=testnet
APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1

# ===== Bridge 合约 (Eunoma testnet 部署) =====
BRIDGE_PACKAGE_ADDRESS=0x8268f56bdd9814d1cc925b861eaa1203d41c7f5425b3d2df887f618ffeb24820
VAULT_RESOURCE_ADDRESS=0x9545e5eaee78bf8b71fcd802624d6182a6c9103fe7969241979163582862108a

# ===== Operator HTTP =====
MAIN_OPERATOR_PORT=3000
PARTNER_OPERATOR_PORT=3001
# Per-partner port (sequential 3001..3006 for slots 1..6)

# ===== Persistence (W2) =====
# Postgres URL — docker-compose 自动起 postgres，dev 默认值如下。
# Prod 替换为真实托管 URL。
DATABASE_URL=postgres://operator:operator@localhost:5432/eunoma

# ===== HTTP Auth (W1) =====
# Bearer token for main operator (any caller hitting /v1/* on main port)
OPERATOR_BEARER_TOKEN=
# Per-partner bearer (slot 1..6)；main → partner 调用时自动带
PARTNER_BEARER_TOKEN_SLOT_1=
PARTNER_BEARER_TOKEN_SLOT_2=
PARTNER_BEARER_TOKEN_SLOT_3=
PARTNER_BEARER_TOKEN_SLOT_4=
PARTNER_BEARER_TOKEN_SLOT_5=
PARTNER_BEARER_TOKEN_SLOT_6=
# 一次性生成 7 个 token：
#   npx tsx scripts/generate_bearer_tokens.ts

# ===== Secrets (W3) — 私钥 =====
# 注意：所有 private key 字段都必须是 0x-prefixed hex string。
# 生成新 keypair：
#   npx tsx scripts/generate_twisted_ed25519_keypair.ts vault
#   npx tsx scripts/generate_twisted_ed25519_keypair.ts recipient
#   npx tsx scripts/generate_twisted_ed25519_keypair.ts user
# 从旧 JSON 文件迁移：
#   npx tsx scripts/migrate_json_secrets_to_env.ts >> .env

# Vault TwistedEd25519 decryption key (32 bytes hex)
# Main operator 用它解密 CA 余额、构造 vault→recipient transfer。**最敏感的一把**。
VAULT_DECRYPTION_KEY_HEX=

# Bridge-spare recipient TwistedEd25519 keypair (32 bytes hex) —— testnet 测试用收款方
RECIPIENT_ENCRYPTION_KEY_HEX=

# Bridge-user TwistedEd25519 keypair (32 bytes hex) —— testnet 测试用 user；生产中每用户自己持
USER_ENCRYPTION_KEY_HEX=

# 7 operator Ed25519 signing keys，base64-encoded JSON array
# Format: [{slot: 0..6, role, private_key: "0x...", public_key: "0x...", address: "0x..."}, ...]
# 必须 7 entries
OPERATOR_KEYS_JSON_B64=

# Admin Ed25519 private key (32 bytes hex)
# 调用 init_vault / init_operator_set / publish_vk / pause / rotate_admin 用
ADMIN_PRIVATE_KEY_HEX=

# Relayer Ed25519 private key (32 bytes hex)
# 提交 update_root_batch 时支付 gas（不签 attestation，只交 tx）
RELAYER_PRIVATE_KEY_HEX=
